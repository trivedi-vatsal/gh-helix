# GitHub organization to back up (required)
GITHUB_ORG=my-org

# Absolute path to the directory where mirrors are stored (required)
# Use forward slashes even on Windows, e.g. D:/GitHubBackups
BACKUP_DIRECTORY=D:/GitHubBackups

# Number of Git operations to run concurrently -- the worker pool size (optional, default: 5)
MAX_PARALLEL=5

# Whether to run `git lfs fetch --all` after every clone/update (optional, default: true)
FETCH_LFS=true

# --- Authentication ---------------------------------------------------------
# Token priority: GITHUB_TOKEN, then GH_TOKEN, then `gh auth token` as a last resort.
# A fine-grained or classic PAT needs at least read access to the org's repositories.
GITHUB_TOKEN=
# GH_TOKEN=

# --- GitHub Enterprise Server (optional) ------------------------------------
# Bare hostname, used only for the `gh auth token` fallback.
# GH_HOST=github.mycompany.com
# Full REST API base URL, used by the Octokit client.
# GITHUB_API_URL=https://github.mycompany.com/api/v3

# Every setting above can also be set in config.json instead; values here
# (and in the real environment) always take precedence over config.json.
